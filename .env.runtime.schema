# Runtime variables (used during application execution)
# @defaultSensitive=false
# @import(./.env.azure.schema, enabled=eq($AUTH_MODE, "azure"))
# ---
#
# @optional @type=port
API_PORT=8000

# API base URL
# @public @type=url
NUXT_API_URL=if(
    eq($APP_MODE, dev),
    http://localhost:${API_PORT},
)

# GitHub token for feedback feature
# @sensitive
NUXT_FEEDBACK_GITHUB_TOKEN=exec(`./scripts/get-secret.sh pass://DCC-KI/FEEDBACK_DEV_GITHUB_TOKEN/TOKEN`)

# Logger level (default: debug)
# @optional @public @type=enum(trace, debug, info, warn, error, fatal)
NUXT_PUBLIC_LOGGER_LOG_LEVEL=if(eq($APP_MODE, dev), debug, info)

# Use dummy data (default: false)
# @type=string
DUMMY=false
