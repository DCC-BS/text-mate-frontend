# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# @plugin(@varlock/proton-pass-plugin@0.0.3)
# @initProtonPass()
# @defaultRequired=true @defaultSensitive=false
# @import(./.env.azure.schema, enabled=eq($AUTH_MODE, "azure"))
# @import(../.env.buildtime.schema)
#  ----------

# Set the auth mode to select the authentication method
# none: no authentication
# azure: use the azure ad authentication see https://dcc-bs.github.io/documentation/nuxt-layers/auth.html#azure-auth-implementation-azure-auth
# @type=enum(none, azure)
AUTH_MODE="none"

# The cache directory for storing huggingface models
CACHE_DIR="~/.cache"

# Hugging face token for downloading the models
# @sensitive
HUGGING_FACE_HUB_TOKEN=protonPass(`pass://DCC-KI/HUGGING_FACE_TOKEN/TOKEN`)

HUGGING_FACE_CACHE_DIR=${CACHE_DIR}/huggingface

# Base url for the llm calls
# @type=url
OPENAI_API_BASE_URL=http://llm:8000/v1

# LLM Key for authentication
# @sensitive
LLM_KEY=none-llm-key

# Model name
LLM_MODEL="Qwen/Qwen3-32B-AWQ"

LLM_HEALTH_CHECK_URL=http://llm:8000/health

# @type=uuid
AZURE_FRONTEND_CLIENT_ID=protonPass(`pass://DCC-KI/TEXTMATE_BACKEND/FRONTEND_CLIENT_ID`)

# Generate with openssl rand -base64 32
# @required @sensitive
HMAC_SECRET=

# @type=enum(debug, info, warn, error, fatal)
LOG_LEVEL=debug

# @type=port
BACKEND_PORT=8000
