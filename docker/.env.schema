# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=true @defaultSensitive=false
# ----------


# The cache directory for storing language tool ngrams and huggingface models
CACHE_DIR="~/.cache"

# Hugging face token for downloading the models
# @sensitive
HUGGING_FACE_HUB_TOKEN=exec(`./scripts/get-secret.sh pass://DCC-KI/HUGGING_FACE_TOKEN/TOKEN`)

HUGGING_FACE_CACHE_DIR=${CACHE_DIR}/huggingface
LANGUAGE_TOOL_CACHE_DIR=${CACHE_DIR}/languagetool

# Base url for the llm calls
# @type=url
OPENAI_API_BASE_URL=http://llm:8000/v1

# LLM Key for authentication
# @sensitive
LLM_KEY=none-lmm-key

# Model name
LLM_MODEL="Qwen/Qwen3-32B-AWQ"

LLM_HEALTH_CHECK_URL=http://llm:8000/health

# @type=uuid
AZURE_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/CLIENT_ID`)

# @type=uuid
AZURE_TENANT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/TENANT_ID`)

# @type=uuid
AZURE_FRONTEND_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_BACKEND/FRONTEND_CLIENT_ID`)

SCOPE_DESCRIPTION="user_impersonation"

# Generate with openssl rand -base64 32
# @required @sensitive
HMAC_SECRET=

# @type=enum(debug, info, warn, error, fatal)
LOG_LEVEL=debug

# @type=port
BACKEND_PORT=8000

# @type=port
LANGUAGE_TOOL_PORT=8010

# @type=url
LANGUAGE_TOOL_API_URL="http://languagetool:${LANGUAGE_TOOL_PORT}/v2"
