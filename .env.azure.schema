# @defaultRequired=true
# ---

# Auth secret for session encryption (generate with: openssl rand -base64 32)
# @sensitive
NUXT_AZURE_AUTH_SECRET=

# Azure AD client ID
NUXT_AZURE_AUTH_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_CLIENT_ID`)

# Azure AD tenant IDi
# @type=uuid
NUXT_AZURE_AUTH_TENANT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_TENANT_ID`)

# Azure AD client secret
# @sensitive
NUXT_AZURE_AUTH_CLIENT_SECRET=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_CLIENT_SECRET`)

# Azure AD API client IDi
# @type=uuid
NUXT_AZURE_AUTH_API_CLIENT_ID=exec(`./scripts/get-secret.sh pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_API_CLIENT_ID`)

# Origin URL for Azure AD authentication
# @public @type=url
NUXT_AZURE_AUTH_ORIGIN="http://localhost:3000/api/auth"
