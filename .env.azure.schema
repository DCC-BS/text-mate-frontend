# @defaultSensitive=false @defaultRequired=true
# ---

# Auth secret for session encryption (generate with: openssl rand -base64 32)
# @sensitive
NUXT_AZURE_AUTH_SECRET=

# Azure AD client ID
# @public
NUXT_AZURE_AUTH_CLIENT_ID=if(
    eq($APP_MODE, dev),
    protonPass(`pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_CLIENT_ID`),
)

# Azure AD tenant ID
# @type=uuid
NUXT_AZURE_AUTH_TENANT_ID=if(
    eq($APP_MODE, dev),
    protonPass(`pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_TENANT_ID`),
)

# Azure AD client secret
# @sensitive
NUXT_AZURE_AUTH_CLIENT_SECRET=if(
    eq($APP_MODE, dev),
    protonPass(`pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_CLIENT_SECRET`),
)

# Azure AD API client ID
# @type=uuid
NUXT_AZURE_AUTH_API_CLIENT_ID=if(
    eq($APP_MODE, dev),
    protonPass(`pass://DCC-KI/TEXTMATE_FRONTEND/AUTH_API_CLIENT_ID`)
)

# Origin URL for Azure AD authentication
# @public @type=url
NUXT_AZURE_AUTH_ORIGIN=if(
    eq($APP_MODE, dev),
    "http://localhost:3000/api/auth",
)
